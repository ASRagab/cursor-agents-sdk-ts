{
  "name": "cursor-agents",
  "version": "0.1.0",
  "description": "TypeScript SDK and CLI for the Cursor Cloud Agents API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cursor-agents": "src/cli/index.ts"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "bunx biome check src/ tests/",
    "lint:fix": "bunx biome check --write src/ tests/",
    "test": "bun test",
    "build": "bun build src/index.ts --outdir dist --target node --format esm"
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ASRagab/cursor-agents-sdk-ts.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  }
}
